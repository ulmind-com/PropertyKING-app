{
  "expo": {
    "name": "PropertyKing",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logoremovebg.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#D4A017"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ulmind.propertyking",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ulmind.propertyking",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCe6KCXl5MO1INT16N9I_kiMwXxwZHJc8o"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PropertyKing to use your location to show nearby properties."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PropertyKing to access your photos to upload property images and avatars."
        }
      ],
      "expo-notifications"
    ],
    "extra": {}
  }
}

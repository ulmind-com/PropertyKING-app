{
  "expo": {
    "name": "PropertyKING",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ulmind.propertyking"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ulmind.propertyking",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCe6KCXl5MO1INT16N9I_kiMwXxwZHJc8o"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PropertyKING to use your location to show nearby properties."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PropertyKING to access your photos to upload property images and avatars."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "5ed33441-30bc-4bc4-80ad-c55f650cc555"
      }
    },
    "owner": "handiman-001"
  }
}
